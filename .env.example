# ─────────────────────────────────────────────────────────────
# reMint — accounts / auth environment
# Copy to .env.local for development, or set these in your host
# (e.g. Vercel → Project → Settings → Environment Variables).
# ─────────────────────────────────────────────────────────────

# REQUIRED — session encryption secret.
# Generate one with:  npx auth secret   (or)   openssl rand -base64 33
AUTH_SECRET=

# REQUIRED — Postgres connection string (Neon, Vercel Postgres, Supabase…).
# e.g. postgres://user:password@host/dbname?sslmode=require
DATABASE_URL=

# OPTIONAL — Google sign-in.
# Create an OAuth 2.0 Client (Web) at:
#   https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:
#   https://YOUR_DOMAIN/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google   (for local dev)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# OPTIONAL — canonical site URL. Set behind proxies / on a custom domain.
# AUTH_URL=https://your-domain.com

# OPTIONAL — password-reset emails via Resend (https://resend.com).
# Without these, the reset link is shown on-screen in demo mode.
# RESEND_API_KEY=
# AUTH_EMAIL_FROM=reMint <noreply@your-domain.com>
